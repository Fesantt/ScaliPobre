{
  "name": "whiteboard-colaborativo",
  "version": "1.0.0",
  "description": "Whiteboard colaborativo em tempo real com WebSocket",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop whiteboard",
    "pm2:restart": "pm2 restart whiteboard",
    "pm2:delete": "pm2 delete whiteboard",
    "pm2:logs": "pm2 logs whiteboard",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "pm2:startup": "pm2 startup",
    "setup": "npm install && node -e \"console.log('Setup completo! Execute npm run pm2:start para iniciar com PM2')\"",
    "logs:clear": "rm -rf logs/*.log || del /Q logs\\*.log"
  },
  "keywords": [
    "whiteboard",
    "collaborative",
    "websocket",
    "real-time"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "ws": "^8.20.0",
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "sqlite3": "^5.1.7",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  }
}
